# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_MINI=gpt-4o-mini
OPENAI_BASE_URL=
OPENAI_USE_RESPONSES=false
OPENAI_VECTOR_STORE_IDS=

# MongoDB
MONGODB_URI=mongodb://localhost:27017/infosec

# ChromaDB
CHROMA_PERSIST_DIRECTORY=./data/chroma

# App
PORT=3000
NODE_ENV=development

# JWT Authentication (required - use strong secrets)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-here
JWT_REFRESH_EXPIRES_IN=30d
