# OpenAI Configuration
OPENAI_API_KEY=sk-placeholder
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_MINI=gpt-4o-mini
OPENAI_BASE_URL=http://host.docker.internal:11434/v1
OPENAI_USE_RESPONSES=false
OPENAI_VECTOR_STORE_IDS=
OPENAI_INGEST_TO_VECTOR_STORES=false

# MongoDB Configuration
MONGODB_URI=mongodb://mongo:27017/infosec

# ChromaDB Configuration
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_PERSIST_DIRECTORY=./data/chroma

# Application Configuration
PORT=3000
NODE_ENV=development

# JWT Authentication (REQUIRED - Generate 32+ character secrets!)
# Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-here
JWT_REFRESH_EXPIRES_IN=30d

# Ollama Configuration (for local LLM)
# Only needed if not using OpenAI
OLLAMA_HOST=host.docker.internal
OLLAMA_PORT=11434

# Frontend Configuration
VITE_API_URL=http://localhost:3001
